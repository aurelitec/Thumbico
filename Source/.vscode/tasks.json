{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "dotnet build Thumbico.slnx",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "rebuild",
      "type": "shell",
      "command": "dotnet build Thumbico.slnx --no-incremental",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "clean",
      "type": "shell",
      "command": "dotnet clean Thumbico.slnx",
      "problemMatcher": []
    },
    {
      "label": "run",
      "type": "shell",
      "command": "dotnet run --project Thumbico/Thumbico.csproj",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "format",
      "type": "shell",
      "command": "dotnet format Thumbico.slnx",
      "problemMatcher": []
    },
    {
      "label": "format: verify",
      "type": "shell",
      "command": "dotnet format Thumbico.slnx --verify-no-changes",
      "problemMatcher": []
    },
    {
      "label": "test",
      "type": "shell",
      "command": "dotnet test --solution Thumbico.slnx",
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": "$msCompile"
    }
  ]
}
