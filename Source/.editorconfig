[*.cs]
indent_size = 4
max_line_length = 120

# License header
file_header_template = Copyright (c) 2011-2026 Aurelitec <https://www.aurelitec.com>\nLicensed under the MIT License. See LICENSE in the repository root for license information.
dotnet_diagnostic.IDE0073.severity = error

# Using directives
csharp_using_directive_placement = outside_namespace:suggestion
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true

# internal and private fields should be _camelCase
dotnet_naming_rule.camel_case_for_private_internal_fields.severity = suggestion
dotnet_naming_rule.camel_case_for_private_internal_fields.symbols  = private_internal_fields
dotnet_naming_rule.camel_case_for_private_internal_fields.style    = camel_case_underscore_style
dotnet_naming_symbols.private_internal_fields.applicable_kinds = field
dotnet_naming_symbols.private_internal_fields.applicable_accessibilities = private, internal
dotnet_naming_style.camel_case_underscore_style.required_prefix = _
dotnet_naming_style.camel_case_underscore_style.capitalization = camel_case

# ... but static and const ones should be PascalCase, with no prefix. Without this the rule above
# also claims them, because it can only match the modifiers a field has, not the ones it lacks.
# A const field counts as static here, so this single rule covers both.
dotnet_naming_rule.pascal_case_for_private_internal_static_fields.severity = suggestion
dotnet_naming_rule.pascal_case_for_private_internal_static_fields.symbols = private_internal_static_fields
dotnet_naming_rule.pascal_case_for_private_internal_static_fields.style   = pascal_case_style
dotnet_naming_symbols.private_internal_static_fields.applicable_kinds = field
dotnet_naming_symbols.private_internal_static_fields.applicable_accessibilities = private, internal
dotnet_naming_symbols.private_internal_static_fields.required_modifiers = static
dotnet_naming_style.pascal_case_style.capitalization = pascal_case
